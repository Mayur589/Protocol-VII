[sub_resource type="Shader" id="Shader_holo_globe"]
code = "shader_type spatial;
render_mode unshaded, cull_disabled, blend_mix, fog_disabled;

uniform sampler2D world_map : source_color;
uniform vec4 glow_color : source_color = vec4(0.0, 0.85, 1.0, 1.0);
uniform float alpha = 0.2;
uniform float glow_strength = 0.5;
uniform float scanline_density = 180.0;

void fragment() {
	vec2 uv = UV;
	vec2 map_uv = vec2(fract(uv.x + TIME * 0.022), uv.y);
	vec3 map_tex = texture(world_map, map_uv).rgb;
	float land_mask = smoothstep(0.34, 0.6, dot(map_tex, vec3(0.3333)));
	float map_outline = smoothstep(0.45, 0.52, land_mask) - smoothstep(0.52, 0.59, land_mask);
	float scan = 0.72 + 0.28 * sin((uv.y + TIME * 0.65) * scanline_density);
	float latitude = 0.85 + 0.15 * sin((uv.y + TIME * 0.2) * 140.0);
	float longitude = 0.85 + 0.15 * sin((uv.x - TIME * 0.25) * 95.0);
	float grid = latitude * longitude;
	float fresnel = pow(1.0 - clamp(dot(normalize(NORMAL), normalize(VIEW)), 0.0, 1.0), 3.1);
	float core = 0.35 + 0.25 * grid;
	float overlay = (land_mask * 0.8 + map_outline * 1.35) * (0.8 + 0.2 * sin(TIME * 2.0));
	vec3 base_color = glow_color.rgb * (0.5 + core);
	vec3 overlay_color = mix(glow_color.rgb, vec3(0.65, 1.0, 1.0), 0.5) * overlay;
	vec3 holo = base_color + overlay_color;
	ALBEDO = holo * 0.16;
	EMISSION = holo * (glow_strength * scan + fresnel * 2.2);
	ALPHA = alpha * (0.82 + fresnel * 0.18);
}"

