[sub_resource type="Shader" id="Shader_scanlines"]
code = "shader_type canvas_item;
uniform float line_strength = 0.1;
uniform float line_density = 220.0;
void fragment() {
	vec4 c = COLOR;	float line = step(0.5, fract(UV.y * line_density));	c.rgb *= 1.0 - (line * line_strength);	COLOR = c;
}
"

